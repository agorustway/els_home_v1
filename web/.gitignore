# See https://help.github.com/articles/ignoring-files/ for more about ignoring files.

# dependencies
/node_modules
/.pnp
.pnp.*
.yarn/*
!.yarn/patches
!.yarn/plugins
!.yarn/releases
!.yarn/versions

# testing
/coverage

# next.js
/.next/
# /out/ - 앱 에셋은 Git 롤백 가능하도록 추적 대상 포함 (2026-03-25)

# production
/build

# misc
.DS_Store
*.pem

# debug
npm-debug.log*
yarn-debug.log*
yarn-error.log*
.pnpm-debug.log*

# build artifacts (do not commit)
build*.log
build_output.txt
error.txt
commit_msg.txt

# env files (can opt-in for committing if needed)
.env*

# vercel
.vercel

# typescript
*.tsbuildinfo
next-env.d.ts

# Agent specific files
AGENT_GUIDELINES.md
DEVELOPMENT_LOG.md