# ══════════════════════════════════════════════════════════════════════════════
# ELS 프로젝트 .gitignore
# 마지막 업데이트: 2026-05-14
# ══════════════════════════════════════════════════════════════════════════════

# ─── Python 캐시 (절대 커밋 금지) ────────────────────────────────────────────────
__pycache__/
*.py[cod]
*$py.class
*.pyo
.venv/
venv/
ENV/

# ─── Node.js 의존성/빌드 ────────────────────────────────────────────────────────
node_modules/
.next/
out/
build/
*.tsbuildinfo

# ─── 환경변수 (보안) ────────────────────────────────────────────────────────────
.env*.local
.env.production
.env.staging
.env*

# ─── IDE/에디터 전용 설정 ──────────────────────────────────────────────────────
.vscode/
.cursor/
.idea/

# ─── AI 도구 캐시/임시 (메모리 파일 등 제외) ────────────────────────────────────
.gemini-clipboard/
.gemini/

# ─── elsbot 빌드 및 디버그물 ──────────────────────────────────────────────────
elsbot/build/
elsbot/dist/
elsbot/*.spec
elsbot/login_debug_*.png
elsbot/els_config.json
elsbot/container_list.xlsx
elsbot/last_search_result.json

# ─── 빌드 로그 및 임시파일 ──────────────────────────────────────────────────────
*.log
*.tmp
*.bak
debug_*.py
debug_*.png
*_debug.png
.tmp_test/
.tmp_issues/
.tmp_profile/
.tmp_profiles/
elsbot/.tmp_profile/
commit_msg.txt
*.html
debug_*.html

# ─── OS 생성 파일 ──────────────────────────────────────────────────────────────
.DS_Store
Thumbs.db
Desktop.ini

# ─── 아카이브 (기합 및 백업) ────────────────────────────────────────────────────
docs/_archive/

# ─── 실행파일 및 대용량 ────────────────────────────────────────────────────────
*.exe
*.msi

# ─── Capacitor/Android 빌드 ────────────────────────────────────────────────────
web/android/app/src/main/assets/public/

# ─── 기타 도구 설정 ────────────────────────────────────────────────────────────
.claude/settings.local.json
els_cleanup_archive_*.zip
_TRASH_BIN_/